    "/api/student/{id}/check": {
      "post": {
        "tags": [
          "Student Submission Operations"
        ],
        "summary": "Check own solution",
        "operationId": "checkSolution",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "reportType",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "MERGED_GRAPH",
              "enum": [
                "TWO_GRAPH",
                "MERGED_GRAPH"
              ]
            }
          },
          {
            "name": "method",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "BRANCH",
              "enum": [
                "BRANCH",
                "BRUTE_FORCE",
                "DP",
                "UNIQUE_LABEL"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/GitComparisonResultDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/comparison/compare-files": {
      "post": {
        "tags": [
          "Comparison Operations"
        ],
        "summary": "Compare two Git repositories provided as ZIP files",
        "operationId": "compareFiles",
        "parameters": [
          {
            "name": "reportType",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "MERGED_GRAPH",
              "enum": [
                "TWO_GRAPH",
                "MERGED_GRAPH"
              ]
            }
          },
          {
            "name": "method",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "BRANCH",
              "enum": [
                "BRANCH",
                "BRUTE_FORCE",
                "DP",
                "UNIQUE_LABEL"
              ]
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "reference",
                  "student"
                ],
                "type": "object",
                "properties": {
                  "reference": {
                    "type": "string",
                    "format": "binary"
                  },
                  "student": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/GitComparisonResultDto"
                }
              }
            }
          }
        }
      }
    },
